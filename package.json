{
  "name": "salesflow-pro",
  "version": "1.0.0",
  "description": "SalesFlow Pro - Professional Sales Management Application",
  "main": "out/main/index.js",
  "author": {
    "name": "SalesFlow Pro",
    "email": "support@salesflowpro.com"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "bcryptjs": "^2.4.3",
    "uuid": "^9.0.0",
    "xlsx": "^0.18.5",
    "date-fns": "^3.3.1",
    "recharts": "^2.12.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3",
    "lucide-react": "^0.344.0",
    "react-hot-toast": "^2.4.1",
    "simple-statistics": "^7.8.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^29.1.4",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.1.0",
    "vite": "^5.1.6"
  },
  "build": {
    "appId": "com.salesflowpro.app",
    "productName": "SalesFlow Pro",
    "copyright": "Copyright © 2024 SalesFlow Pro",
    "mac": {
      "category": "public.app-category.business",
      "icon": "resources/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ]
    },
    "dmg": {
      "title": "SalesFlow Pro",
      "backgroundColor": "#0f172a",
      "window": { "width": 600, "height": 420 }
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/",
        "to": "resources/"
      }
    ]
  }
}
